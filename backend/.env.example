PORT=3001
ALEO_RPC_URL=https://api.provable.com/v2

# Admin key for oracle price updates and protocol admin transactions
PRIVATE_KEY=APrivateKey1...
ADMIN_ADDRESS=aleo1...

# Second operator key for approve_settlement (must differ from admin)
OPERATOR2_PRIVATE_KEY=APrivateKey1...
OPERATOR2_ADDRESS=aleo1...

# CoinMarketCap API key (optional, one of 5 oracle sources)
CMC_API_KEY=your_coinmarketcap_api_key_here

# Frontend URL for CORS (your Vercel domain)
FRONTEND_URL=https://your-app.vercel.app
